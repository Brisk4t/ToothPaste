{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Electron: Build",
      "type": "shell",
      "command": "npm run electron:build",
      "options": {
        "cwd": "${workspaceFolder}/web"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Electron: Dev",
      "type": "shell",
      "command": "npm run electron:dev",
      "options": {
        "cwd": "${workspaceFolder}/web"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
