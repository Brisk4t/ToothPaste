# Build variant: 4MB flash, software MBEDTLS, RGB LED on GPIO 10

# Flash configuration
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHMODE="dio"
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHFREQ="80m"

# ATECC608A I2C pin assignment (board-specific, overrides Kconfig defaults of 21/22)
CONFIG_ATECC608A_TCUSTOM=y
CONFIG_ATCA_I2C_SDA_PIN=41
CONFIG_ATCA_I2C_SCL_PIN=40
CONFIG_ATCA_I2C_ADDRESS=0xC0
CONFIG_ATCA_I2C_BAUD_RATE=100000

# Software crypto path (no ATECC hardware ECDSA)
CONFIG_TOOTHPASTE_SOFTWARE_CRYPTO=y

# RGB LED pin
CONFIG_TOOTHPASTE_RGB_LED_PIN=10
